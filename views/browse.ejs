<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Anylearn Browse</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
rel="stylesheet"
integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
crossorigin="anonymous">

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/browse.css">

</head>

<body class="<%= role %>">

    <header class="top">
        <% if(role === "guest") { %>
            <a href="/browse" class="brand">Anylearn</a>
        <% } %>

        <% if(role !== "guest") { %>
            <a href="/dashboard" class="brand">Anylearn</a>
        <% } %>

        <div class="top-right">

            <span class="pill"><%= role %></span>

            <% if(role === "guest") { %>

                <span>
                    <form action="/" method="get">
                        <button type="submit" class="top-btn">Login</button>
                    </form>
                </span>

                <span>
                    <form action="/register" method="get">
                        <button type="submit" class="top-btn">Signup</button>
                    </form>
                </span>

            <% } %>

            <% if(role !== "guest") { %>

                <div class="dropdown">
                    <a class="btn btn-primary dropdown-toggle"
                    href="#"
                    role="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">

                        <%= username %>

                    </a>

                    <ul class="dropdown-menu">

                        <li>
                            <a class="dropdown-item" href="/profile">
                                ข้อมูลส่วนตัว
                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <form action="/logout" method="POST" class="m-0">
                                <button type="submit" class="dropdown-item">
                                    ออกจากระบบ
                                </button>
                            </form>
                        </li>

                    </ul>
                </div>

            <% } %>

        </div>
    </header>

    <main class="container mt-4">

        <h2 class="page-title mb-3">คอร์สทั้งหมด</h2>

        <div class="search-bar mb-4">

            <form action="/browse" method="GET" class="d-flex">

                <input
                    type="text"
                    name="q"
                    class="form-control me-2"
                    placeholder="ค้นหาคอร์ส..."
                    value="<%= query || '' %>"
                >

                <button type="submit" class="btn btn-primary">
                    Search
                </button>

            </form>

        </div>

        <div class="course-grid">

            <% if(courses && courses.length > 0){ %>

                <% courses.forEach(course => { %>

                    <div class="course-card">

                        <a href="/course/<%= course.course_id %>" class="course-link">

                            <img
                                src="<%= course.thumbnail || '/images/course-placeholder.png' %>"
                                class="course-image"
                            >

                            <div class="course-body">

                                <h5 class="course-title">
                                    <%= course.title %>
                                </h5>

                                <p class="course-teacher">
                                    โดย <strong><%= course.teacher_name || '' %></strong>
                                </p>

                            </div>

                        </a>

                    </div>

                <% }) %>

            <% } else { %>

                <p>ไม่พบคอร์ส</p>

            <% } %>

        </div>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>