<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anylearn - Register</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/registration.css">
</head>

<body>
    <main class="register-wrap">
        <section class="register-card">
            <header class="register-header">
                <p class="brand">Anylearn</p>
                <h1>สร้างบัญชีผู้ใช้</h1>
            </header>

            <% if (error) { %>
                <div class="error" role="alert"><%= error %></div>
            <% } %>

            <form action="/register" method="post" class="register-form">
                <label for="username">ชื่อผู้ใช้</label>
                <input id="username" type="text" placeholder="ชื่อผู้ใช้ของคุณ" name="username" value="<%= username %>" autocomplete="username">

                <label for="fullname">ชื่อจริง</label>
                <input id="fullname" type="text" placeholder="ชื่อ-นามสกุล" name="fullname" value="<%= fullname %>" autocomplete="fullname">

                <label for="email">อีเมล</label>
                <input id="email" type="email" placeholder="xxx@example.com" name="email" value="<%= email %>" autocomplete="email">

                <label for="password">รหัสผ่าน</label>
                <input id="password" type="password" placeholder="รหัสผ่านของคุณ" name="password" value="<%= password %>" autocomplete="new-password">

                <label for="cfmpassword">ยืนยันรหัสผ่าน</label>
                <input id="cfmpassword" type="password" placeholder="ยืนยันรหัสผ่าน" name="cfmpassword" value="<%= chkpassword %>" autocomplete="new-password">

                <button type="submit">สมัคร</button>
            </form>

            <p class="back-login">มีบัญชีอยู่แล้ว? <a href="/">เข้าสู่ระบบที่นี่เลย!</a></p>
        </section>
    </main>
</body>

</html>
