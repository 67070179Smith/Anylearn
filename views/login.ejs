<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anylearn - เข้าสู่ระบบ</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>
    <main class="login-wrap">
        <section class="login-card">
            <header class="login-header">
                <p class="brand">Anylearn</p>
                <h1>ยินดีต้อนรับกลับ</h1>
                <p class="subtitle">เข้าสู่ระบบเพื่อเรียนรู้ต่อได้เลย!</p>
            </header>

            <% if (error) { %>
                <div class="error" role="alert"><%= error %></div>
            <% } %>

            <form method="POST" action="/login" class="login-form">
                <label for="username">ชื่อผู้ใช้</label>
                <input id="username" type="text" name="username" value="<%= username || '' %>" placeholder="ชื่อผู้ใช้..." autocomplete="username" required>

                <label for="password">รหัสผ่าน</label>
                <input id="password" type="password" name="password" placeholder="รหัสผ่าน..." autocomplete="current-password" required>

                <button type="submit" class="primary-btn">เข้าสู่ระบบ</button>
            </form>

            <form action="/guest" method="post" class="guest-form">
                <button type="submit" class="ghost-btn">เข้าสู่ระบบโดยไม่ใช้บัญชี</button>
            </form>

            <p class="register-link">ไม่มีบัญชี? <a href="/register">สมัครสมาชิกตรงนี้เลย!</a></p>
        </section>
    </main>
</body>

</html>
