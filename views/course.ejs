<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= course.title %> | Anylearn</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/course.css">

</head>

<body class="<%= role %>">

<!-- แถบ Navigation -->
<header class="top">

    <% if(role === "guest") { %>
        <a href="/browse" class="brand">Anylearn</a>
    <% } %>

    <% if(role !== "guest") { %>
        <a href="/dashboard" class="brand">Anylearn</a>
    <% } %>

    <div class="top-right">

        <span class="pill"><%= role %></span>

        <% if(role === "guest") { %>

            <form action="/" method="get">
                <button type="submit" class="top-btn">Login</button>
            </form>

            <form action="/register" method="get">
                <button type="submit" class="top-btn">Signup</button>
            </form>

        <% } %>

        <% if(role !== "guest") { %>

        <div class="dropdown">

            <a class="btn btn-primary dropdown-toggle"
               href="#"
               role="button"
               data-bs-toggle="dropdown">

               <%= username %>

            </a>

            <ul class="dropdown-menu">
                <li>
                    <form action="/logout" method="POST" class="m-0">
                        <button type="submit" class="dropdown-item">
                            ออกจากระบบ
                        </button>
                    </form>
                </li>

            </ul>

        </div>

        <% } %>

    </div>

</header>
<!-- ปิดไว้จะได้เห็นง่ายๆ -->

<section class="content">

    <div class="panel course-page">

        <% if (editMode) { %>
            <form method="POST" action="/teacher/course/<%= course.course_id %>/edit" enctype="multipart/form-data">
        <% } %>


        <div class="course-toolbar">

            <% if (role === "guest" || (role === "learner" && !enrolled)) { %>
                <a href="/browse" class="back-btn">
                    &lt; กลับ
                </a>
            <% } else { %>
                <a href="/dashboard" class="back-btn">
                    &lt; กลับ
                </a>
            <% } %>

            <% if (role === "teacher") { %>

                <% if (!editMode) { %>

                    <button 
                        class="btn btn-outline-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#studentsModal">

                        นักเรียน (<%= students ? students.length : 0 %>)

                    </button>

                    <a href="/course/<%= course.course_id %>/edit" class="toolbar-btn">
                        แก้ไข
                    </a>

                <% } else { %>

                    <button
                        type="submit"
                        class="btn btn-outline-danger"
                        formaction="/teacher/course/<%= course.course_id %>/delete"
                        formmethod="POST"
                        formnovalidate
                        onclick="return confirm('Delete this course permanently?')">

                        ลบคอร์ส

                    </button>

                <% } %>

            <% } %>

        </div>

        <!-- COURSE HERO -->
        <div class="course-hero">

            <div class="course-thumbnail-wrapper">
                <img src="<%= course.thumbnail %>" class="course-thumbnail">
            </div>

            <div class="course-meta">

                <% if (editMode) { %>

                    <input
                        type="text"
                        name="title"
                        class="edit-title"
                        value="<%= course.title %>"
                    >

                    <div class="edit-thumbnail">
                        <label for="thumbnail">เปลี่ยนรูปปกคอร์ส</label>
                        <input id="thumbnail" type="file" name="thumbnail" accept="image/*">
                    </div>

                <% } else { %>

                    <h1 class="course-title">
                        <%= course.title %>
                    </h1>

                    <p class="course-teacher">
                        โดย <strong><%= course.teacher_name %></strong>
                    </p>

                <% } %>

            </div>

        </div>

        <!-- COURSE DESCRIPTION -->

        <div class="course-description">

            <h2>คอร์สนี้สอนอะไร?</h2>

            <% if (editMode) { %>

                <textarea
                    name="description"
                    class="edit-description"
                ><%= course.description %></textarea>

            <% } else { %>

                <p>
                    <%= course.description %>
                </p>

            <% } %>

        </div>

        <!-- COURSE TOPICS -->
        <div class="course-topics">
        <% if (editMode) { %>
                    <div class="course-toolbar">
                        <button
                            type="button"
                            class="toolbar-btn"
                            data-bs-toggle="modal"
                            data-bs-target="#addTopicModal"
                        >
                            เพิ่มบท
                        </button>

                        <button
                            type="button"
                            class="toolbar-btn"
                            data-bs-toggle="modal"
                            data-bs-target="#manageTopicsModal"
                        >
                            จัดการบทเรียน
                        </button>
                    </div>
            <% } %>
            <h2 class="content-head-title">เนื้อหา</h2>

            <% if(role === "guest") { %>

                <div class="access-gate">
                    <p>สมัครสมาชิกเพื่อเข้าถึงเนื้อหาคอร์ส</p>

                    <a href="/register" class="btn btn-primary">
                        สมัครสมาชิค
                    </a>
                </div>

            <% } else if(role === "learner" && !enrolled) { %>

                <div class="access-gate">
                    <p>เข้าร่วมคอร์สนี้เพื่อดูเนื้อหา</p>

                    <form method="POST" action="/course/<%= course.course_id %>/enroll">
                        <button class="btn btn-success">
                            เข้าร่วมเลย!
                        </button>
                    </form>
                </div>

            <% } else { %>

            <div class="accordion" id="topicsAccordion">

            <% if (topics && topics.length > 0) { %>

                <% topics.forEach((topic) => { %>

                <div class="accordion-item">

                    <h2 class="accordion-header">

                        <button
                            class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#topic-<%= topic.topic_id %>">

                            <%= topic.title %>

                        </button>

                    </h2>

                    <div
                        id="topic-<%= topic.topic_id %>"
                        class="accordion-collapse collapse"
                        data-bs-parent="#topicsAccordion">

                        <div class="accordion-body">

                            <% if (topic.contents && topic.contents.length > 0) { %>

                                <ul class="content-list">

                                <% topic.contents.forEach((content) => { %>

                                    <li class="content-item">

                                        <div class="lesson-content">

                                            <div class="content-display">

                                                <% if (content.content_type === "text") { %>

                                                    <p class="lesson-text">
                                                        <%= content.content_text %>
                                                    </p>

                                                <% } %>

                                                <% if (content.content_type === "image") { %>

                                                    <img
                                                        src="<%= content.image_url %>"
                                                        class="lesson-image"
                                                    >

                                                <% } %>

                                                <% if (content.content_type === "video") { %>

                                                    <div class="lesson-video">
                                                        <iframe
                                                            src="<%= content.content_text %>"
                                                            frameborder="0"
                                                            allowfullscreen>
                                                        </iframe>
                                                    </div>

                                                <% } %>

                                            </div>

                                        </div>

                                        <% if(editMode){ %>

                                            <div class="lesson-actions">

                                                <button
                                                    type="submit"
                                                    formmethod="POST"
                                                    formaction="/teacher/content/<%= content.content_id %>/delete"
                                                    class="btn btn-danger btn-sm">
                                                    ลบ
                                                </button>

                                            </div>

                                        <% } %>

                                    </li>

                                <% }) %>

                                </ul>

                            <% } else { %>

                                <p class="empty-content">ยังไม่มีเนื้อหา</p>

                            <% } %>
                            
                            <% if(editMode){ %>

                                <button
                                type="button"
                                class="btn btn-primary btn-sm mt-2"
                                data-bs-toggle="modal"
                                data-bs-target="#addContentModal"
                                data-topic-id="<%= topic.topic_id %>">

                                    + เพิ่มเนื้อหา

                                </button>

                            <% } %>
                        </div>

                    </div>

                </div>

                <% }) %>

            <% } else { %>

                <p class="empty-content">ยังไม่มีบทเรียน</p>

            <% } %>

            </div>
            <% if(role === "learner") { %>

                <div class="mt-4 text-center feedback-cta">

                    <a href="#"
                    data-bs-toggle="modal"
                    data-bs-target="#feedbackModal"
                    class="fw-semibold">

                        รู้สึกยังไงกับคอร์สนี้บ้าง? บอกอาจารย์ได้เลย!

                    </a>

                </div>

            <% } %>
            <% } %>
        </div>

        <% if (editMode) { %>

            <div class="edit-actions">

                <button type="submit" class="save-button">
                    บันทึก
                </button>

                <a href="/course/<%= course.course_id %>" class="cancel-button">
                    ยกเลิก
                </a>

            </div>
            </form>
        <% } %>

    </div>

</section>

<!-- Modal เพื่อนรัก-->
<div class="modal fade" id="addTopicModal" tabindex="-1">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    เพิ่มบทเรียน
                </h5>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal">
                </button>

            </div>

            <form action="/teacher/course/<%= course.course_id %>/topic" method="POST">

                <div class="modal-body">

                    <input
                        type="text"
                        name="title"
                        class="form-control"
                        placeholder="ชื่อบทเรียน..."
                        required
                    >

                </div>

                <div class="modal-footer">

                    <button
                        type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                        ยกเลิก
                    </button>

                    <button
                        type="submit"
                        class="btn btn-primary">
                        เพิ่มบทเรียน
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>

<div class="modal fade" id="manageTopicsModal" tabindex="-1">

  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">
            จัดการบทเรียน (<%= topics.length %>)
        </h5>

        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <ul class="list-group">

        <% topics.forEach(topic => { %>

          <li class="list-group-item d-flex justify-content-between align-items-center">

            <span class="fw-semibold"><%= topic.title %></span>

            <form method="POST"
                  action="/teacher/topic/<%= topic.topic_id %>/delete">

              <button
                class="btn btn-danger btn-sm"
                onclick="return confirm('ต้องการลบบทเรียนนี้?')"
              >
                ลบ
              </button>

            </form>

          </li>

        <% }) %>

        </ul>

      </div>

    </div>
  </div>

</div>

<div class="modal fade" id="addContentModal" tabindex="-1">

  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">

        <h5 class="modal-title">
          เพิ่มเนื้อหา
        </h5>

        <button class="btn-close" data-bs-dismiss="modal"></button>

      </div>

      <form method="POST"
        id="addContentForm"
        enctype="multipart/form-data">

        <div class="modal-body">

            <input type="hidden" name="topic_id" id="contentTopicId">
            <input type="hidden" name="course_id" value="<%= course.course_id %>">

          <label class="form-label">ประเภทเนื้อหา</label>

          <select id="contentType"
                  name="content_type"
                  class="form-select mb-3">

            <option value="text">ข้อความ</option>
            <option value="video">วิดีโอ</option>
            <option value="image">รูปภาพ</option>

          </select>

          <!-- TEXT / VIDEO INPUT -->

          <div id="textGroup">

            <label id="textLabel" class="form-label">
              เนื้อหา
            </label>

            <input
              type="text"
              name="content_text"
              id="contentInput"
              class="form-control"
              placeholder="พิมพ์เนื้อหาในนี้...">

          </div>

          <!-- IMAGE INPUT -->

          <div id="imageGroup" style="display:none;">

            <label class="form-label">
              อัพโหลดรูปภาพ
            </label>

            <input
              type="file"
              name="image"
              class="form-control"
              accept="image/*">

          </div>

        </div>

        <div class="modal-footer">

          <button
            type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
            ยกเลิก
          </button>

          <button
            type="submit"
            class="btn btn-primary">
            เพิ่มเนื้อหา
          </button>

        </div>

      </form>

    </div>
  </div>

</div>

<div class="modal fade" id="studentsModal" tabindex="-1">

  <div class="modal-dialog">

    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">นักเรียนในคอร์ส</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <% if (!students || students.length === 0) { %>

            <p>ยังไม่มีนักเรียน</p>

        <% } else { %>

            <% students.forEach(student => { %>

                <div class="d-flex justify-content-between align-items-center mb-2">

                    <span><%= student.username %></span>

                    <form method="POST"
                        action="/teacher/course/<%= course.course_id %>/student/<%= student.user_id %>/remove">

                        <button class="btn btn-danger btn-sm">
                            ลบนักเรียน
                        </button>

                    </form>

                </div>

            <% }) %>

        <% } %>

      </div>

    </div>

  </div>

</div>

<div class="modal fade" id="feedbackModal" tabindex="-1">

  <div class="modal-dialog">

    <div class="modal-content">

      <div class="modal-header">

        <h5 class="modal-title">
            ส่งความคิดเห็นถึงอาจารย์
        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal">
        </button>

      </div>

      <form method="POST" action="/course/<%= course.course_id %>/feedback">

        <div class="modal-body">

            <textarea
                name="text"
                class="form-control"
                rows="4"
                placeholder="พิมพ์ความคิดเห็นของคุณที่นี่..."
                required
            ></textarea>

        </div>

        <div class="modal-footer">

            <button
                type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">

                ยกเลิก

            </button>

            <button
                type="submit"
                class="btn btn-primary">

                ส่งความคิดเห็น

            </button>

        </div>

      </form>

    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script>

    const typeSelect = document.getElementById("contentType")
    const textGroup = document.getElementById("textGroup")
    const imageGroup = document.getElementById("imageGroup")
    const textLabel = document.getElementById("textLabel")
    const textInput = document.getElementById("contentInput")

    typeSelect.addEventListener("change", function(){

        const type = this.value

        if(type === "text"){

            textGroup.style.display = "block"
            imageGroup.style.display = "none"

            textLabel.innerText = "Text"
            textInput.placeholder = "Enter lesson text"

        }

        if(type === "video"){

            textGroup.style.display = "block"
            imageGroup.style.display = "none"

            textLabel.innerText = "Video URL"
            textInput.placeholder = "Paste video URL"

        }

        if(type === "image"){

            textGroup.style.display = "none"
            imageGroup.style.display = "block"

        }

    })

    const addContentModal = document.getElementById("addContentModal")

    addContentModal.addEventListener("show.bs.modal", function(event){

        const button = event.relatedTarget
        const topicId = button.getAttribute("data-topic-id")

        const form = document.getElementById("addContentForm")

        form.action = "/teacher/topic/" + topicId + "/content"

        document.getElementById("contentInput").value = ""

    })
</script>

</body>
</html>
