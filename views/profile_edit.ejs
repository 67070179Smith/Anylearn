<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/profile.css">
    <title>
        <%= data.username %>'s Profile
    </title>
</head>

<body>
    <header class="top">
        <div class="brand">Anylearn</div>
        <div class="toclass">
            <href>Placeholder</href>
        </div>
        <div class="top-right">
            <span class="pill">
                <%= role %>
            </span>
            <% if(role==="guest" ) { %>
                <span>
                    <form action="/" method="get">
                        <button type="submit" class="top-btn">Login</button>
                    </form>
                </span>
                <span>
                    <form action="/register" method="get">
                        <button type="submit" class="top-btn">Signup</button>
                    </form>
                </span>
                <% } %>
                    <% if(role !=="guest" ) { %>
                        <div class="dropdown">
                            <a class="btn btn-primary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                                aria-expanded="false">
                                <%= data.username %>
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/profile">ข้อมูลส่วนตัว</a></li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li>
                                    <form action="/logout" method="POST" class="m-0">
                                        <button type="submit" class="dropdown-item">ออกจากระบบ</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        <% } %>
        </div>
    </header>
    <div id="content">
        <img src="<%= data.profile_pic || '/images/default.jpg' %>" alt="">
        <form action="/editProfile" method="post">
            <h1>Edit Your profile</h1>
            <div class="label">
                <label for="fullname">Fullname:</label>
                <input id="fullname" type="text" name="fullname" value="<%= data.full_name %>" autocomplete="fullname" required>
            </div>
            
            <div class="label">
                <label for="username">Username:</label>
                <input id="username" type="text" name="username" value="<%= data.username %>" autocomplete="username" required>
            </div>

            <div class="label">
                <label for="email">Email:</label>
                <input id="email" type="text" name="email" value="<%= data.email %>" autocomplete="email" required>
            </div>

            <div class="form-floating">
                <textarea class="form-control" name="description" placeholder="Write your description here" id="floatingTextarea2" style="height: 100px"><%= data.description %></textarea>
                <label for="floatingTextarea2">Description</label>
            </div>

            <div class="label">
                <span>Gender:</span>
                <div class="dropdown">
                    <input type="hidden" name="gender" id="genderInput" value="<%= data.gender %>">
                    <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="gender" name="gender">
                        <%= data.gender %>
                    </button>
                    <ul class="dropdown-menu">
                        <li><button type="button" class="dropdown-item" onclick="setGender('Male')">Male</button></li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>
                        <li><button type="button" class="dropdown-item" onclick="setGender('Female')">Female</button></li>
                    </ul>
                </div>
            </div>
        
            <div class="label">
                <span>Birthdate:</span>
                <input type="date" id="birthdate" name="birthdate" value="<%= data.birthdate %>">
            </div>
            
            <div class="label">
                <label for="profile_pic">Profile Picture:</label>
                <input id="profile_pic" type="url" name="profile_pic" placeholder="url of your picture" value="<%= data.profile_pic %>">
            </div>

            <button type="submit" class="btn btn-success" id="saveBtn">Save change</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <script>
        function setGender(gender) {
            document.getElementById("gender").textContent = gender;
            document.getElementById("genderInput").value = gender
        }
    </script>
</body>

</html>