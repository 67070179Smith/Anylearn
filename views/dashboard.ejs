<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anylearn Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="<%= role %>">
    <header class="top">
        <% if(role === "guest") { %>
            <a class="brand">Anylearn</a>
        <% } %>

        <% if(role !== "guest") { %>
        <a href="/dashboard" class="brand">Anylearn</a>
        <% } %>
        <div class="top-right">
            <span class="pill"><%= role %></span>
            <% if(role === "guest") { %>
                <span>
                    <form action="/" method="get">
                        <button type="submit" class="top-btn">Login</button>
                    </form>
                </span>
                <span>
                    <form action="/register" method="get">
                        <button type="submit" class="top-btn">Signup</button>
                    </form>
                </span>
            <% } %>
            <% if(role !== "guest") { %>
                <div class="dropdown">
                    <a class="btn btn-primary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <%= username %>
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/profile">ข้อมูลส่วนตัว</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form action="/logout" method="POST" class="m-0">
                                <button type="submit" class="dropdown-item">ออกจากระบบ</button>
                            </form>
                        </li>
                    </ul>
                </div>
            <% } %>
        </div>
    </header>
    <div class="layout">

        <section class="content">
            <h1 class="Carmen">My Course</h1>
            <div class="panel toolbar">
                <!--แถบค้นหา-->
                <form method="GET" action="/dashboard" class="search">
                    <input 
                        type="text" 
                        name="q"
                        placeholder="ค้นหา"
                        value="<%= typeof query !== 'undefined' ? query : '' %>"
                    >
                </form>
                <!--เพิ่มคอร์ส + ดูผลตอบรับ -->
                <% if (role === "teacher") { %>

                    <button class="btn create-btn" id="create-course-button" data-bs-toggle="modal" data-bs-target="#addCourseModal">
                        + Add Course
                    </button>

                    <button class="feedback-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#feedbackListModal">

                        Feedback

                    </button>

                <% } %>
                <% if (role === "student") { %>

                    <a href="/browse" class="btn browse-btn">
                        Browse
                    </a>

                <% } %>
            </div>
            <div class="panel courses">
                <% if (!courses || courses.length === 0) { %>
                    <div class="empty">
                        <% if (role === "teacher") { %>
                            <div class="teacher-noc">
                                <a>
                                    You have no courses yet.
                                </a>
                                <button class="btn create-btn" id="create-course-button" data-bs-toggle="modal" data-bs-target="#addCourseModal">
                                    + Add Course
                                </button>
                            </div>
                        <% } else if (role === "student") { %>
                            You are not enrolled in any course yet.
                        <% } else { %>
                            Guest mode has no course data.
                        <% } %>
                    </div>
                <% } %>
                <% if (courses && courses.length > 0) { %>
                    <% courses.forEach((course) => { %>

                        <a href="/course/<%= course.course_id %>" class="course-link">
                            <article class="card">

                                <% if (course.thumbnail) { %>
                                    <img src="<%= course.thumbnail %>" class="course-img">
                                <% } %>

                                <div class="card-body">

                                    <h3 class="title"><%= course.title %></h3>
                                    <div class="meta-row">
                                        <% if (role === "teacher") { %>
                                            <span>Created: <%= course.created_at || "-" %></span>
                                        <% } %>
                                    </div>
                                    <span class="tag" title="Instructor: <%= course.teacher_name || " -" %>"><%= course.teacher_name || "-" %></span>
                                    
                                    </div>
                            </article>
                        </a>
                    <% }) %>
                <% } %>
            </div>
        </section>
    </div>

    <!-- หน้าเพิ่มคอร์ส -->
    <div class="modal fade" id="addCourseModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
      
                <form action="/teacher/course/create" method="POST" enctype="multipart/form-data">
        
                    <div class="modal-header">
                        <h5 class="modal-title">Create New Course</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        
                        <div class="mb-3">
                            <label class="form-label">Course Thumbnail</label>
                            <input type="file"
                                name="thumbnail"
                                class="form-control"
                                accept="image/*">
                            <div class="form-text">
                                JPG, PNG recommended. Max 2MB.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Course Title</label>
                            <input type="text" name="title" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="description" class="form-control" rows="3"></textarea>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Create Course
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="feedbackListModal" tabindex="-1">

        <div class="modal-dialog modal-lg">

            <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Student Feedback
                </h5>

                <button class="btn-close" data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body">

                <% if(!feedbackList || feedbackList.length === 0) { %>

                    <p>No feedback yet.</p>

                <% } else { %>

                    <% feedbackList.forEach(f => { %>

                        <div class="border rounded p-3 mb-3">

                            <div class="d-flex justify-content-between">

                                <strong>
                                    <%= f.username %>
                                </strong>

                                <small class="text-muted">
                                    <%= f.timestamp %>
                                </small>

                            </div>

                            <div class="text-muted mb-1">

                                Course: <%= f.course_title %>

                            </div>

                            <p class="mb-0">
                                <%= f.text %>
                            </p>

                        </div>

                    <% }) %>

                <% } %>

            </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

</body>
</html>
