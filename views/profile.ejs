<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/profile.css">
    <title>
        Edit Profile
    </title>
</head>

<body>
    <header class="top">
        <div class="brand">Anylearn</div>
        <div class="toclass">
            <href>Placeholder</href>
        </div>
        <div class="top-right">
            <span class="pill">
                <%= role %>
            </span>
            <% if(role==="guest" ) { %>
                <span>
                    <form action="/" method="get">
                        <button type="submit" class="top-btn">Login</button>
                    </form>
                </span>
                <span>
                    <form action="/register" method="get">
                        <button type="submit" class="top-btn">Signup</button>
                    </form>
                </span>
                <% } %>
                    <% if(role !=="guest" ) { %>
                        <div class="dropdown">
                            <a class="btn btn-primary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                                aria-expanded="false">
                                <%= data.username %>
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/profile">ข้อมูลส่วนตัว</a></li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li>
                                    <form action="/logout" method="POST" class="m-0">
                                        <button type="submit" class="dropdown-item">ออกจากระบบ</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        <% } %>
        </div>
    </header>
    <div id="content">
        <img src="<%= data.profile_pic || '/images/default.jpg' %>" alt="">
        <div id="userData">
            <h1>Your profile</h1>
            <div class="label">
                <label for="fullname">Fullname: <%= data.full_name %></label>
            </div>
            
            <div class="label">
                <label for="username">Username: <%= data.username %></label>
            </div>

            <div class="label">
                <label for="email">Email: <%= data.email %></label>
            </div>

            <div class="form-floating">
                <textarea class="form-control" name="description" placeholder="Write your description here" id="floatingTextarea2" style="height: 100px" readonly><%= data.description ? data.description : 'No data' %></textarea>
                <label for="floatingTextarea2">Description</label>
            </div>

            <div class="label">
                <span>Gender:</span>
                <div class="dropdown">
                    <button class="btn btn-secondary">
                        <%= data.gender ? data.gender : 'No data' %>
                    </button>
                </div>
            </div>
        
            <div class="label">
                <span>Birthdate: <%= data.birthdate ? data.birthdate : 'No data' %></span>
            </div>

            <a href="/editprofile" class="btn btn-success" id="saveBtn">Edit profile</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <script>
        function setGender(gender) {
            document.getElementById("gender").textContent = gender;
            document.getElementById("genderInput").value = gender
        }
    </script>
</body>

</html>